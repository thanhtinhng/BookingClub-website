MONGO_URI= "Mongo_URI"
PORT="PORT"
DB_NAME=
JWT_SECRET="UUID chuoi ngau nhien"
JWT_REFRESH_SECRET="UUID chuoi ngau nhien"
JWT_EXPIRE="Eg: 60, "2 days", "10h", "7d""
REFRESH_TOKEN_EXPIRE="7d"
EMAIL_VERIFICATION_EXPIRE_MINUTES="60"
PASSWORD_RESET_EXPIRE_MINUTES="30"

# SMTP
# SMTP_PASS must be a Gmail App Password (16 chars) generated after enabling 2FA.
# có thể tạo app password tại: https://myaccount.google.com/apppasswords
# (không cần điền nếu không sử dụng chức năng gửi email thật)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="email_của_bạn@gmail.com"
SMTP_PASS="<GMAIL_APP_PASSWORD_16_CHARS>"
SMTP_FROM="email_của_bạn@gmail.com"

CORS_ALLOWED_ORIGINS="URL FE"

COOKIE_SERCURE=
COOKIE_SAME_SITE=
